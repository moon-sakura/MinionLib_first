<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
    <PropertyGroup>
        <MinionLib_PkgRoot>$(MSBuildThisFileDirectory)../</MinionLib_PkgRoot>
    </PropertyGroup>

    <Target Name="MinionLib_AutoCopy" AfterTargets="PostBuildEvent" Condition="'$(ModsPath)' != ''">
        <ItemGroup>
            <MinionCoreFiles Include="$(MinionLib_PkgRoot)lib/**/MinionLib.dll"/>
            <MinionCoreFiles Include="$(MinionLib_PkgRoot)Content/MinionLib.pck"/>
            <MinionCoreFiles Include="$(MinionLib_PkgRoot)Content/MinionLib.json"/>
        </ItemGroup>
        <Message Text="[MinionLib] Copying core files to $(ModsPath)MinionLib/" Importance="high"/>
        <Copy SourceFiles="@(MinionCoreFiles)"
              DestinationFolder="$(ModsPath)MinionLib/"
              SkipUnchangedFiles="true"/>
    </Target>

</Project>
