<Project>
    <!-- 自动更新 json 中的版本号 -->
    <Target Name="UpdateManifestVersion" BeforeTargets="BeforeBuild;PreparePckForPack">
        <PropertyGroup>
            <RitsuVersion>$([System.IO.Path]::GetFileName($(PkgSTS2_RitsuLib)))</RitsuVersion>
            <BaseLibVersion>$([System.IO.Path]::GetFileName($(PkgAlchyr_Sts2_BaseLib)))</BaseLibVersion>

            <ManifestTemplateFile>$(MSBuildProjectDirectory)/$(MSBuildProjectName).template.json</ManifestTemplateFile>
            <ManifestTemplateFile Condition="'$(AdapteeId)' != ''">$(MSBuildThisFileDirectory)Adapters.template.json</ManifestTemplateFile>

            <ManifestOutputFile>$(IntermediateOutputPath)$(MSBuildProjectName).json</ManifestOutputFile>
        </PropertyGroup>

        <Message Text="Updating version in $(ManifestOutputFile) to $(Version)" Importance="high"/>

        <ItemGroup>
            <FileLines Include="$([System.IO.File]::ReadAllText($(ManifestTemplateFile))
                .Replace('__THIS_NAME__', '$(MSBuildProjectName)')
                .Replace('__THIS_VERSION__', '$(Version)')
                .Replace('__GAME_VERSION__', '$(Sts2Version)')
                .Replace('__ADAPTEE_ID__', '$(AdapteeId)')
                .Replace('__STS2-RitsuLib_VERSION__', '$(RitsuVersion)')
                .Replace('__BaseLib_VERSION__', '$(BaseLibVersion)'))"/>
        </ItemGroup>

        <WriteLinesToFile File="$(ManifestOutputFile)" Lines="@(FileLines)" Overwrite="true" WriteOnlyWhenDifferent="true"/>
    </Target>

    <!-- 构建后自动将此模组的 dll, manifest 和依赖模组的文件复制到 mods 目录 -->
    <Target Name="CopyToModsFolderOnBuild" AfterTargets="PostBuildEvent">
        <Message Text="Copying .dll and manifest to mods folder." Importance="high"/>
        <Copy SourceFiles="$(TargetPath)" DestinationFolder="$(ModsPath)$(MSBuildProjectName)/"/>
        <Copy SourceFiles="$(ManifestOutputFile)" DestinationFolder="$(ModsPath)$(MSBuildProjectName)/"/>
    </Target>

    <!--执行 Godot 导出命令将 .pck 导出到 mods 目录 -->
    <Target Name="GodotPublish" AfterTargets="Publish" Condition="'$(GodotPath)' != '' and Exists('$(GodotPath)') and '$(IsInnerGodotExport)' != 'true'">
        <Message Text="Exporting Godot .pck to mods folder" Importance="high"/>
        <Exec Command="&quot;$(GodotPath)&quot; --headless --export-pack &quot;BasicExport&quot; &quot;$(ModsPath)$(MSBuildProjectName)/$(MSBuildProjectName).pck&quot;" EnvironmentVariables="IsInnerGodotExport=true;MSBUILDDISABLENODEREUSE=1" ContinueOnError="WarnAndContinue"/>
    </Target>

    <Target Name="GodotPublishSkipped" AfterTargets="Publish" Condition="'$(GodotPath)' == '' or !Exists('$(GodotPath)')">
        <Message Text="Skipping Godot .pck export because GodotPath is not configured." Importance="high"/>
    </Target>
</Project>
