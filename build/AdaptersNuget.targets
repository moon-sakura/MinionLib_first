<Project>
    <!-- NuGet 包元数据定义 -->
    <PropertyGroup>
        <PackageId>FuYnAloft.Sts2.$(MSBuildProjectName)</PackageId>
        <Authors>FuYnAloft</Authors>
        <Description>Adapters for $(AdapteeId) to better work with MinionLib. 适用于 $(AdapteeId) 的适配器，使其更好地与 MinionLib 配合使用。</Description>
        <PackageLicenseExpression>LGPL-3.0-only</PackageLicenseExpression>
        <RepositoryUrl>https://github.com/FuYnAloft/MinionLib</RepositoryUrl>
        <PackageReadmeFile>README.md</PackageReadmeFile>

        <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
        <IncludeSymbols>true</IncludeSymbols>
        <SymbolPackageFormat>snupkg</SymbolPackageFormat>
        <IncludeContentInPack>false</IncludeContentInPack>
        <TargetsForTfmSpecificContentInPackage>$(TargetsForTfmSpecificContentInPackage);AddFilesToNuGetPackage</TargetsForTfmSpecificContentInPackage>
    </PropertyGroup>

    <!-- 防呆 -->
    <Target Name="EnforceVersionOnPack" BeforeTargets="AddFilesToNuGetPackage">
        <Error Condition="'$(Version)' == '100.0.0.0-dev'" Text="[打包失败] 发布 NuGet 包时需要指定版本号！示例: -p:Version=0.1.0"/>
    </Target>

    <!-- 定义 AutoCopy Targets 的路径属性 -->
    <PropertyGroup>
        <AutoCopyTargetsTemplatePath>$(MSBuildThisFileDirectory)AdaptersAutoCopy.template.targets</AutoCopyTargetsTemplatePath>
        <AutoCopyTargetsPath>$(IntermediateOutputPath)$(PackageId).targets</AutoCopyTargetsPath>
    </PropertyGroup>

    <!-- 打包前准备 AutoCopy Targets 文件 -->
    <Target Name="PrepareTargetsForPack" BeforeTargets="AddFilesToNuGetPackage">
        <ItemGroup>
            <TargetsFileLines Include="$([System.IO.File]::ReadAllText($(AutoCopyTargetsTemplatePath))
                .Replace('--PROJECT-NAME--', '$(MSBuildProjectName)'))"/>
        </ItemGroup>
        <WriteLinesToFile File="$(AutoCopyTargetsPath)" Lines="@(TargetsFileLines)" Overwrite="true" WriteOnlyWhenDifferent="true"/>
    </Target>

    <!-- 将特定文件塞入 NuGet 包中 -->
    <Target Name="AddFilesToNuGetPackage" DependsOnTargets="ResolveProjectReferences;Build">
        <ItemGroup>
            <TfmSpecificPackageFile Include="$(ManifestOutputFile)">
                <PackagePath>Content/$(MSBuildProjectName).json</PackagePath>
            </TfmSpecificPackageFile>
            <TfmSpecificPackageFile Include="$(MSBuildProjectDirectory)/README.md">
                <PackagePath>README.md</PackagePath>
            </TfmSpecificPackageFile>
            <TfmSpecificPackageFile Include="$(AutoCopyTargetsPath)">
                <PackagePath>build/$(PackageId).targets</PackagePath>
            </TfmSpecificPackageFile>
        </ItemGroup>
    </Target>
</Project>
