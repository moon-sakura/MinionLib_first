<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
    <PropertyGroup>
        <_--SAFE-PROJECT-NAME--_PkgRoot>$(MSBuildThisFileDirectory)../</_--SAFE-PROJECT-NAME--_PkgRoot>
        <ShouldAutoCopyMinionLib Condition="'$(ShouldAutoCopyMinionLib)' == ''">true</ShouldAutoCopyMinionLib>
    </PropertyGroup>

    <Target Name="_--SAFE-PROJECT-NAME--_AutoCopy"
            AfterTargets="PostBuildEvent"
            Condition="'$(ModsPath)' != '' AND '$(ShouldAutoCopyMinionLib)' == 'true'">
        <ItemGroup>
            <_--SAFE-PROJECT-NAME--_Files Include="$(_--SAFE-PROJECT-NAME--_PkgRoot)lib/**/--PROJECT-NAME--.dll"/>
            <_--SAFE-PROJECT-NAME--_Files Include="$(_--SAFE-PROJECT-NAME--_PkgRoot)Content/--PROJECT-NAME--.json"/>
        </ItemGroup>
        <Message Text="[--PROJECT-NAME--] Copying core files to $([System.IO.Path]::Combine('$(ModsPath)', '--PROJECT-NAME--'))" Importance="high"/>
        <Copy SourceFiles="@(_--SAFE-PROJECT-NAME--_Files)"
              DestinationFolder="$([System.IO.Path]::Combine('$(ModsPath)', '--PROJECT-NAME--'))"
              SkipUnchangedFiles="true"/>
    </Target>
</Project>
